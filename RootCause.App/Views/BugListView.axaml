<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RootCause.App.ViewModels"
             x:Class="RootCause.App.Views.BugListView"
             x:DataType="vm:BugListViewModel">

    <!-- ROOT GRID -->
    <Grid>

        <!-- ================= MAIN CONTENT ================= -->
        <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="24">

            <!-- Buttons -->
            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8">

                        <Button Content="Open"
                        Margin="8,0,0,0"
                        Background="#497EF1"
                        Foreground="White"
                        Command="{Binding OpenBugDetailsCommand}"
                        IsEnabled="{Binding SelectedBug}"/>
                <Button Content="Create"
                        Background="#2BE92B"
                        Foreground="Black"
                        Command="{Binding CreateBugCommand}" />

                <Button Content="Refresh"
                        Background="#3A3A3A"
                        Foreground="White"
                        Command="{Binding RefershBugsCommand}" />

            </StackPanel>

            <!-- Title -->
            <TextBlock Grid.Row="1"
                       Text="Bug List"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0,0,0,12"/>

            <!-- Search -->
            <Grid Grid.Row="2"
                  ColumnDefinitions="Auto,*,Auto,Auto,Auto"
                  ColumnSpacing="12"
                  Margin="0,0,0,30">

                <!-- Search Type -->
                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Text="Search Type" Foreground="#CCCCCC"/>
                    <ComboBox ItemsSource="{Binding SearchTypes}"
                              SelectedItem="{Binding SearchType}"
                              Background="#2A2A2A"
                              Foreground="White"
                              Width="150"/>
                </StackPanel>

                <!-- Search -->
                <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock Text="Search" Foreground="#CCCCCC"/>
                    <TextBox PlaceholderText="Search bugs..."
                             Text="{Binding SearchText}"
                             Background="#2A2A2A"
                             Foreground="White"/>
                </StackPanel>

                <!-- Severity -->
                <StackPanel Grid.Column="2" Spacing="4">
                    <TextBlock Text="Severity" Foreground="#CCCCCC"/>
                    <ComboBox ItemsSource="{Binding Severities}"
                              SelectedItem="{Binding SearchSeverity}"
                              Background="#2A2A2A"
                              Foreground="White"
                              Width="150"/>
                </StackPanel>

                <!-- From -->
                <StackPanel Grid.Column="3" Spacing="4">
                    <TextBlock Text="From" Foreground="#CCCCCC"/>
                    <DatePicker SelectedDate="{Binding FromDate}"
                                Background="#2A2A2A"
                                Foreground="White"/>
                </StackPanel>

                <!-- To -->
                <StackPanel Grid.Column="4" Spacing="4">
                    <TextBlock Text="To" Foreground="#CCCCCC"/>
                    <DatePicker SelectedDate="{Binding ToDate}"
                                Background="#2A2A2A"
                                Foreground="White"/>
                </StackPanel>

            </Grid>

            <!-- Table -->
            <DataGrid Grid.Row="3"
                      ItemsSource="{Binding Bugs}"
                      SelectedItem="{Binding SelectedBug}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Title" Binding="{Binding Title}"/>
                    <DataGridTextColumn Header="Error Message" Binding="{Binding ErrorMessage}" />
                    <DataGridTextColumn Header="Root Cause" Binding="{Binding RootCause}"/>
                    <DataGridTextColumn Header="Fix" Binding="{Binding Fix}" Width="300" />
                    <DataGridTextColumn Header="Stack Tags" Binding="{Binding StackTags}" />
                    <DataGridTextColumn Header="Time To Solve (Min)" Binding="{Binding TimeToSolve}" />
                    <DataGridTextColumn Header="Severity" Binding="{Binding Serverity}" />
                    <DataGridTextColumn Header="Created At"
                                        Binding="{Binding CreatedAt}"
                                        />
                </DataGrid.Columns>

            </DataGrid>
        </Grid>

        <!-- ================= POPUP OVERLAY ================= -->
        <Grid IsVisible="{Binding IsCreatePopupOpen}"
              Background="#80000000"
              ZIndex="1000">

            <Border Width="420"
                    Padding="20"
                    Background="#1E1E1E"
                    CornerRadius="12"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                <StackPanel Spacing="12">

                    <!-- Title -->
                    <TextBlock Text="Create Bug"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="White"/>

                    <!-- Title Field -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Title"
                                   FontWeight="SemiBold"
                                   Foreground="#CCCCCC"/>
                        <TextBox Text="{Binding Title}"
                                 Background="#2A2A2A"
                                 Foreground="White"/>
                    </StackPanel>

                    <!-- Error Message -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Error Message"
                                   FontWeight="SemiBold"
                                   Foreground="#CCCCCC"/>
                        <TextBox Text="{Binding ErrorMessage}"
                                 Background="#2A2A2A"
                                 Foreground="White"/>
                    </StackPanel>

                    <!-- Root Cause -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Root Cause"
                                   Foreground="#CCCCCC"/>
                        <TextBox Text="{Binding RootCause}"
                                 Background="#2A2A2A"
                                 Foreground="White"/>
                    </StackPanel>

                    <!-- Fix -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Fix"
                                   Foreground="#CCCCCC"/>
                        <TextBox Text="{Binding Fix}"
                                 Background="#2A2A2A"
                                 Foreground="White"/>
                    </StackPanel>

                    <!-- Stack Tags -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Stack Tags"
                                   Foreground="#CCCCCC"/>
                        <TextBox Text="{Binding StackTags}"
                                 Background="#2A2A2A"
                                 Foreground="White"/>
                    </StackPanel>

                    <!-- Time -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Time To Solve (min)"
                                   Foreground="#CCCCCC"/>
                        <TextBox Text="{Binding TimeToSolve}"
                                 Background="#2A2A2A"
                                 Foreground="White"/>
                    </StackPanel>

                    <!-- Severity -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Severity"
                                   Foreground="#CCCCCC"/>
                        <ComboBox ItemsSource="{Binding Severities}"
                                  SelectedItem="{Binding Serverity}"
                                  Background="#2A2A2A"
                                  Foreground="White"/>
                    </StackPanel>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Spacing="10"
                                Margin="0,10,0,0">

                        <Button Content="Cancel"
                                Background="#3A3A3A"
                                Foreground="White"
                                Padding="10,4"
                                Command="{Binding CancelCreateCommand}"/>

                        <Button Content="Save"
                                Background="#0A84FF"
                                Foreground="White"
                                Padding="10,4"
                                Command="{Binding SubmitBugCommand}"/>
                    </StackPanel>

                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</UserControl>