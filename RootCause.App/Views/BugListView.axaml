<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RootCause.App.ViewModels"
             x:Class="RootCause.App.Views.BugListView"
             x:DataType="vm:BugListViewModel">

    <Grid RowDefinitions="Auto,Auto,*" Margin="24">

        <TextBlock Grid.Row="0"
                   Text="Bug List" FontSize="24"
                   FontWeight="Bold" Margin="0,0,0,12"/>

        <TextBox Grid.Row="1"
                 PlaceholderText="Search bugs..."
                 Text="{Binding SearchText}"
                 Margin="0,0,0,12"/>

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Bugs}"
                  SelectedItem="{Binding SelectedBug}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  CanUserReorderColumns="True"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Title"
                                    Binding="{Binding Title}"
                                    Width="200"/>
                <DataGridTextColumn Header="Error Message"
                                    Binding="{Binding ErrorMessage}"
                                    Width="250"/>
                <DataGridTextColumn Header="Root Cause"
                                    Binding="{Binding RootCause}"
                                    Width="200"/>
                <DataGridTextColumn Header="Fix"
                                    Binding="{Binding Fix}"
                                    Width="200"/>
                <DataGridTextColumn Header="Stack Tags"
                                    Binding="{Binding StackTags}"
                                    Width="150"/>
                <DataGridTextColumn Header="Time To Solve (min)"
                                    Binding="{Binding TimeToSolve}"
                                    Width="150"/>
                <DataGridTextColumn Header="Severity"
                                    Binding="{Binding Serverity}"
                                    Width="100"/>
                <DataGridTextColumn Header="Created At"
                                    Binding="{Binding CreatedAt, StringFormat='{}{0:dd MMM yyyy}'}"
                                    Width="120"/>
            </DataGrid.Columns>

        </DataGrid>
    </Grid>
</UserControl>