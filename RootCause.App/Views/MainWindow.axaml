<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RootCause.App.ViewModels"
        xmlns:views="using:RootCause.App.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="RootCause.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="RootCause" Width="1100" Height="700">

   <Window.DataTemplates>
        <!-- Maps ViewModel → View automatically -->
        <DataTemplate DataType="vm:DashboardViewModel">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="vm:BugListViewModel">
            <views:BugListView />
        </DataTemplate>
        <DataTemplate DataType="vm:StatsViewModel">
            <views:StatsView />
        </DataTemplate>
    </Window.DataTemplates>

    <Grid ColumnDefinitions="200,*">

        <!-- Sidebar -->
        <StackPanel Grid.Column="0" Spacing="8" Margin="12">
            <Button Content="Dashboard"
                    Command="{Binding NavigateToDashboardCommand}"
                    HorizontalAlignment="Stretch"/>
            <Button Content="Bug List"
                    Command="{Binding NavigateToBugListCommand}"
                    HorizontalAlignment="Stretch"/>
            <Button Content="Stats"
                    Command="{Binding NavigateToStatsCommand}"
                    HorizontalAlignment="Stretch"/>
        </StackPanel>

        <!-- Main content area — swaps views here -->
        <ContentControl Grid.Column="1"
                        Content="{Binding CurrentPage}" />
    </Grid>

</Window>

